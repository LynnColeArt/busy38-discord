{
  "type": "plugin-ui",
  "version": "1",
  "summary": "Discord plugin admin policy controls for scope, runtime settings, and diagnostics.",
  "required_api": [
    "/api/plugins/{plugin_id}/ui/debug",
    "/api/plugins/{plugin_id}/ui/scope",
    "/api/plugins/{plugin_id}/ui/settings",
    "/api/plugins/{plugin_id}/ui/validate"
  ],
  "plugin_identity": {
    "id": "busy-38-discord",
    "aliases": ["busy-38-discord", "discord", "busy38-discord"]
  },
  "sections": [
    {
      "id": "scope",
      "title": "Scope Policy",
      "kind": "form",
      "scope": "admin",
      "visibility": "default-open",
      "actions": [
        {
          "id": "scope",
          "label": "Read scope policy",
          "method": "GET",
          "path": "/api/plugins/{plugin_id}/ui/scope",
          "description": "Load the persisted Discord scope policy.",
          "entry_point": "actions:handle_scope"
        },
        {
          "id": "scope",
          "label": "Save scope policy",
          "method": "POST",
          "path": "/api/plugins/{plugin_id}/ui/scope",
          "description": "Validate and persist Discord scope mode and rules.",
          "entry_point": "actions:handle_scope"
        }
      ]
    },
    {
      "id": "settings",
      "title": "Runtime Settings",
      "kind": "form",
      "scope": "admin",
      "visibility": "default-open",
      "actions": [
        {
          "id": "settings",
          "label": "Read settings",
          "method": "GET",
          "path": "/api/plugins/{plugin_id}/ui/settings",
          "description": "Load the effective Discord runtime settings.",
          "entry_point": "actions:handle_settings"
        },
        {
          "id": "settings",
          "label": "Save settings",
          "method": "POST",
          "path": "/api/plugins/{plugin_id}/ui/settings",
          "description": "Validate and persist Discord runtime settings.",
          "entry_point": "actions:handle_settings"
        }
      ]
    },
    {
      "id": "validate",
      "title": "Validation",
      "kind": "form",
      "scope": "admin",
      "visibility": "collapsed",
      "actions": [
        {
          "id": "validate",
          "label": "Validate policy",
          "method": "POST",
          "path": "/api/plugins/{plugin_id}/ui/validate",
          "description": "Dry-run Discord scope and settings validation.",
          "entry_point": "actions:handle_validate"
        }
      ]
    },
    {
      "id": "diagnostics",
      "title": "Diagnostics",
      "kind": "form",
      "scope": "admin",
      "visibility": "default-open",
      "actions": [
        {
          "id": "debug",
          "label": "Run plugin debug",
          "method": "GET",
          "path": "/api/plugins/{plugin_id}/ui/debug",
          "description": "Inspect effective Discord policy, paths, and diagnostics.",
          "entry_point": "actions:handle_debug"
        }
      ]
    }
  ]
}
